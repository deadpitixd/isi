extern(std) string let(int, string);
extern(std) int charToAscii(string);

extern(std) string typeAsString(string);
int typeAsInt(string in){
    string dataType = typeAsString(in);
    #they are based of Value.hpp in isi source code#
    if (dataType == "int"){ return 0; }
    if (dataType == "float"){ return 1; }
    if (dataType == "string"){ return 2; }
    if (dataType == "bool"){ return 3; }
    if (dataType == "char"){ return 4; }
    if (dataType == "void"){ return 5; }
    return NULL;
}

#prevents data loss when converting float->int#
const int floatToInt(float in){
    #trims the float#
    int i = in;
    #gets the floating point#
    float fpoint = in - i;
    if (i == in){
        return i;
    }
    if (fpoint > 0.5)
    {
        return i + 1;
    }
    else {if (fpoint == 0.5)
    {
        return i + 1;
    }
    }
    else
    {
        return i;
    }

}

int test(){
    auto v = 4.4;
    print(false,"\n");
    print(v,"\n");
    const int c = 0;
    const string str = "Hello World!";
    print(let(c, str),"\n");
    return 0;
}
exit(test());