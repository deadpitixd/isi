const int NULL = -2147483647;
const int true = 1;
const int false = 0;

int isNull(float in){
    if (in == NULL){
        return 1;
    }
    else
    {
        return 0;
    }
}
string String(float in){
    if (isNull(in)){
        return "";
    }
    #string concat turns floats int strings#
    return in + "";
}
