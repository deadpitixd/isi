int x = 3;
int __ISI_EXCEPT_TYPE_ERR = 1;

string String(float in){
    return in + "";
}


int main(){
    print(String(3.141),"\n");
    if (x > 4){
        return 0;
    }
    else{
        throw("x is bigger than 4 (" + String(x) + ")", __ISI_EXCEPT_TYPE_ERR, 2);
    }
}

const int out = main();
if (out != 0){
    print("\nExecution failed with error code '" + x + "'\n");
}
else
{
    print("\nExecution successful\n");
}
exit(out);